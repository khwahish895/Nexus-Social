{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "createdAt", "updatedAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "imageUrl", "likesCount", "commentsCount", "createdAt", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "authorId", "text", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "userId", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Relationship between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "followerId", "followingId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string" },
        "senderId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "postId": { "type": "string" },
        "text": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "recipientId", "senderId", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Social media posts"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on posts"
    },
    "posts/{postId}/likes/{userId}": {
      "schema": "Like",
      "description": "Likes on posts"
    },
    "followers/{relationshipId}": {
      "schema": "Follow",
      "description": "Follower relationships"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
